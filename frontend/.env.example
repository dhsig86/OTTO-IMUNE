# ──────────────────────────────────────────────────────────────
# OTTO-IMUNE — Variáveis de Ambiente
# Copie para .env.local e preencha os valores.
# NUNCA commite .env.local no repositório.
# ──────────────────────────────────────────────────────────────

# ── Firebase Client (público — exposto no browser) ────────────
# Firebase Console → Configurações do projeto → Seus apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=otto-ecosystem.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=otto-ecosystem
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=otto-ecosystem.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (privado — somente servidor) ────────────────
# Firebase Console → Configurações do projeto → Contas de serviço → Nova chave privada
# Substitua quebras de linha reais por \n no valor da chave.
FIREBASE_PROJECT_ID=otto-ecosystem
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Integração OTTO PWA (embed / iframe) ──────────────────────
# Origem exata do OTTO PWA que pode embutir este módulo via iframe.
# Sem barra no final. Dev: http://localhost:3001 | Prod: https://otto-pwa.vercel.app
NEXT_PUBLIC_OTTO_ALLOWED_PARENT_ORIGIN=https://otto-pwa.vercel.app
