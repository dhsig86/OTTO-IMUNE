rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Pacientes: acesso apenas ao dono ou via admin SDK (server-side)
    match /patients/{patientId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      // Permitir criação quando ownerUid ainda não existe (primeiro registro)
      allow create: if request.auth != null;
    }

    // Avaliações de elegibilidade
    match /calculator_runs/{runId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.auth.uid;

      // Escrita somente via Admin SDK (server-side) — bloqueada no cliente
      allow write: if false;
    }

    // Rascunhos de relatórios e prescrições
    match /report_drafts/{draftId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.createdBy.uid;

      allow write: if false;
    }

    match /prescription_drafts/{draftId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.createdBy.uid;

      allow write: if false;
    }

    // Bloquear qualquer outra coleção
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
